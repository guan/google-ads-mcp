# Google Ads API Configuration
# Required for querying ad performance metrics
# See docs/ARCHITECTURE.md for setup guide

# Google Ads API OAuth Credentials
# 1. Create a Google Cloud project at https://console.cloud.google.com
# 2. Enable the Google Ads API
# 3. Create OAuth 2.0 credentials (Desktop application)
# 4. Run scripts/get_refresh_token.py to obtain a refresh token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Developer Token
# Apply at: https://ads.google.com/aw/apicenter
# Test accounts work with any developer token
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Google Ads Account IDs
# Login Customer ID: Your MCC (Manager) account ID (no dashes)
# Customer ID: The ad account to query (no dashes)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
GOOGLE_ADS_CUSTOMER_ID=1234567890

# MCP Server Configuration
# Port for the MCP server to listen on
PORT=3000

# Host to bind the server to (0.0.0.0 for remote access, localhost for local only)
HOST=0.0.0.0

# Node environment (development, production, test)
NODE_ENV=production

# Authentication mode (set to 'false' for local Claude Code usage without OAuth)
# When false, uses GOOGLE_ADS_REFRESH_TOKEN directly (no login required)
# When true, requires Google OAuth login (for team/multi-user setups)
REQUIRE_AUTH=false

# Google OAuth Configuration (for team auth flow)
# 1. Create OAuth 2.0 credentials at https://console.cloud.google.com
# 2. Set authorized redirect URI to: http://localhost:3000/auth/callback
# 3. Request scope: email (for user identification)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret_here
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/auth/callback

# Session Configuration
# Generate a secure random secret with: openssl rand -base64 32
# This is used to sign session cookies
SESSION_SECRET=your_random_32_char_secret_here

# Session time-to-live in milliseconds (default: 24 hours)
SESSION_TTL=86400000
